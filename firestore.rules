rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if user has admin custom claim
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Public read access for magazine content — only admins can write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /tags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /issues/{issueId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /media/{mediaId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Names for name generator - public read, admin write
    match /names/{nameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Name suggestions - anyone can create (rate limited), admin can read/delete
    match /nameSuggestions/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['firstName', 'lastName', 'createdAt'])
                    && request.resource.data.firstName is string
                    && request.resource.data.firstName.size() <= 100
                    && request.resource.data.lastName is string
                    && request.resource.data.lastName.size() <= 100;
      allow read, update, delete: if isAdmin();
    }

    // Name ratings - anyone can create (with validation), public read
    match /nameRatings/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'rating', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 100
                    && request.resource.data.rating is int
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;
      allow read: if true;
      allow update, delete: if isAdmin();
    }

    // Contact form - anyone can create (with validation), only admins can read/manage
    match /contactMessages/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'email', 'message', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 200
                    && request.resource.data.message is string
                    && request.resource.data.message.size() <= 2000;
      allow read, update, delete: if isAdmin();
    }

    // Update subscribers - anyone can create (with validation), only admins can read/manage
    match /updateSubscribers/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'email', 'phone', 'region', 'notes', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 200
                    && request.resource.data.phone is string
                    && request.resource.data.phone.size() <= 50
                    && request.resource.data.notes is string
                    && request.resource.data.notes.size() <= 2000;
      allow read, update, delete: if isAdmin();
    }

    // Admin collection - restricted to the admin themselves
    match /admins/{userId} {
      allow read, write: if isAdmin() && request.auth.uid == userId;
    }
  }
}
